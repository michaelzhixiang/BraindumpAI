# Database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/braindump

# Anthropic API key for AI features (brain dump processing, nudges)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Session secret for express-session (use a random string)
SESSION_SECRET=change-me-to-a-random-string

# Replit Auth (only needed if using Replit Auth)
# REPL_ID=your-repl-id
# ISSUER_URL=https://replit.com/oidc
